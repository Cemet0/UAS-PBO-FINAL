# =============================================================================
# EMBERLORD — Environment Variables (Template)
# =============================================================================
# Salin file ini ke .env dan sesuaikan nilainya.
#
# Cara penggunaan:
#   - Backend membaca .env secara otomatis.
#   - Backend menyajikan nilai LLM ke frontend via endpoint /api/env-config.js.
#   - Cukup set variabel di bawah, lalu jalankan backend & buka frontend.
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_PORT=8080

# ── Database (default: H2 In-Memory) ──────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:h2:mem:emberlorddb;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=

# ── JPA / Hibernate ───────────────────────────────────────────────────────────
SPRING_JPA_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=true

# ── H2 Console ────────────────────────────────────────────────────────────────
SPRING_H2_CONSOLE_ENABLED=true
SPRING_H2_CONSOLE_PATH=/h2-console
SPRING_H2_CONSOLE_WEB_ALLOW_OTHERS=true

# ── File Upload ───────────────────────────────────────────────────────────────
MAX_FILE_SIZE=15MB
MAX_REQUEST_SIZE=15MB

# ── Chatbot / LLM (EmberBot) ──────────────────────────────────────────────────
# Pilih provider: ollama | openai | gemini | github
LLM_PROVIDER=ollama

# Provider: Ollama (lokal, tanpa token)
OLLAMA_API_URL=http://localhost:11434/v1/chat/completions
OLLAMA_MODEL=llama3.2

# Provider: OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Provider: Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Provider: GitHub Models
GITHUB_TOKEN=
GITHUB_MODEL=gpt-4o-mini
GITHUB_API_URL=https://models.inference.ai.azure.com/chat/completions

# ── Frontend ──────────────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:8080/api
