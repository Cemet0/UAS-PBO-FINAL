# =============================================================================
# EMBERLORD — Environment Variables
# =============================================================================
# Salin file ini ke .env dan sesuaikan nilainya.
#
# Cara penggunaan:
#   - Backend (Spring Boot): Variabel dibaca otomatis dari environment.
#   - Frontend: Salin frontend/config.js ke frontend/config.local.js
#     atau ubah langsung di frontend/config.js.
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_PORT=8080

# ── Database (default: H2 In-Memory) ──────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:h2:mem:emberlorddb;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=

# ── JPA / Hibernate ───────────────────────────────────────────────────────────
SPRING_JPA_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=true

# ── H2 Console ────────────────────────────────────────────────────────────────
SPRING_H2_CONSOLE_ENABLED=true
SPRING_H2_CONSOLE_PATH=/h2-console
SPRING_H2_CONSOLE_WEB_ALLOW_OTHERS=true

# ── File Upload ───────────────────────────────────────────────────────────────
MAX_FILE_SIZE=15MB
MAX_REQUEST_SIZE=15MB

# ── Chatbot / LLM (EmberBot) ──────────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_MODEL=llama3.2
GITHUB_API_URL=http://localhost:11434/v1/chat/completions

# ── Frontend ──────────────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:8080/api
